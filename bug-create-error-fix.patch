  }
}

// ⭐ 新增：解析 productID 获取错误
function parseProductIDError(response) {
  const reason = response?.reason || '未知错误';

  // 错误消息映射
  const errorMap = {
    'error_page': {
      message: '禅道页面显示错误',
      getSuggestion: () => {
        if (response.pageTitle?.includes('登录')) {
          return '禅道登录已过期，请先在禅道标签页登录，然后重试';
        }
        if (response.bodyPreview?.includes('404')) {
          return `执行ID不存在或已删除\n页面: ${response.pageTitle}\n请检查执行ID是否正确`;
        }
        if (response.bodyPreview?.includes('403') || response.bodyPreview?.includes('Access denied')) {
          return '没有访问该执行的权限，请联系管理员';
        }
        return `页面无法访问\n页面: ${response.pageTitle}\n请检查:\n1. 执行ID是否正确\n2. 是否有访问权限\n3. 网络连接是否正常`;
      }
    },
    'iframe_not_found': {
      message: '页面结构异常',
      suggestion: '禅道页面可能正在加载或版本不兼容\n建议:\n1. 刷新禅道页面\n2. 等待页面完全加载后重试\n3. 检查禅道版本是否兼容'
    },
    'bug_create_link_not_found': {
      message: '无法创建Bug',
      suggestion: '当前执行可能没有创建Bug的权限\n建议:\n1. 检查执行配置\n2. 联系管理员获取权限\n3. 尝试在其他执行中创建Bug'
    },
    'no_zentao_tab': {
      message: '未找到禅道标签页',
      suggestion: '请确保已打开禅道页面\n建议:\n1. 打开禅道任意页面\n2. 确保已登录\n3. 刷新扩展后重试'
    },
    'timeout': {
      message: '请求超时',
      suggestion: '获取产品ID超时\n建议:\n1. 检查网络连接\n2. 刷新禅道页面\n3. 稍后重试'
    },
    'iframe_load_timeout': {
      message: '页面加载超时',
      suggestion: '禅道页面加载超时\n建议:\n1. 刷新禅道页面\n2. 等待页面完全加载\n3. 检查网络连接'
    },
    'iframe_access_denied': {
      message: '无法访问页面内容',
      suggestion: '无法访问禅道页面iframe\n建议:\n1. 检查扩展权限\n2. 刷新禅道页面\n3. 重新加载扩展'
    }
  };

  const errorInfo = errorMap[reason] || {
    message: '获取 productID 失败',
    suggestion: `未知错误: ${reason}\n建议:\n1. 刷新禅道页面\n2. 检查网络连接\n3. 重新登录禅道`
  };

  // 如果错误信息有动态获取建议的方法，调用它
  if (typeof errorInfo.getSuggestion === 'function') {
    return {
      message: errorInfo.message,
      suggestion: errorInfo.getSuggestion()
    };
  }

  return {
    message: errorInfo.message,
    suggestion: errorInfo.suggestion
  };
}

